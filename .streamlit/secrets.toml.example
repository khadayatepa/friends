# Copy this file to  .streamlit/secrets.toml  for LOCAL runs,
# and paste the SAME content into Streamlit Cloud's "Secrets" box for DEPLOY.
# NEVER commit the real secrets.toml to GitHub (see .gitignore).

# ============================================================
# TLS connection WITHOUT a wallet  (what you are using)
# ============================================================
# 1. In the OCI Console -> your ADB -> Network / "Mutual TLS (mTLS)
#    authentication", set it to NOT required (allow TLS).
# 2. Database Connection -> Connection Strings -> TLS  -> copy the
#    "prashant26ai_medium" descriptor (the long (description=...) string).
# 3. Paste that whole descriptor as `dsn` below.

[oracle]
user = "FRIENDS_APP"
password = "Fr1ends#Map2026!"   # the password you set in 01_create_user.sql
dsn = """(description=(retry_count=20)(retry_delay=3)(address=(protocol=tcps)(port=1521)(host=adb.<region>.oraclecloud.com))(connect_data=(service_name=<long_id>_prashant26ai_medium.adb.oraclecloud.com))(security=(ssl_server_dn_match=yes)))"""
# No wallet_b64 / wallet_password needed for TLS.

[app]
# Optional: set a password to gate the app (leave blank for no gate).
password = ""
highlight_window_hours = 2
